# --- REQUIRED ---
# NEXT_PUBLIC_GEMINI_API_KEY: Your Google AI API key (from Google AI Studio).
# AI Studio automatically injects this at runtime if named correctly.
NEXT_PUBLIC_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# NEXT_PUBLIC_CONVEX_URL: The URL of your Convex deployment (e.g., https://happy-monkey-123.convex.cloud).
# This is required for the application to boot and connect to the database.
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"

# --- OPTIONAL ---
# GEMINI_MODEL: The model version to use. Defaults to gemini-1.5-flash.
GEMINI_MODEL="gemini-1.5-flash"

# GEMINI_BASE_URL: Custom endpoint for the Gemini API if using a proxy.
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/models"

# APP_URL: The public URL of this application.
APP_URL="http://localhost:3000"

